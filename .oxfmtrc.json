{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/crates/oxc_formatter/schema.json",
  "ignorePatterns": ["dist/**"],
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always"
}
